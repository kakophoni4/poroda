generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  passwordHash String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Тексты интерфейса сайта (редактируются в админке «Тексты сайта»)
model SiteCopy {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  orders        Order[]
  promoUses     PromoUse[]
  notifications UserNotification[]
  favorites     UserFavorite[]
}

model Category {
  id        String    @id @default(cuid())
  slug      String    @unique
  title     String
  sortOrder Int       @default(0)
  products  Product[]
}

model Product {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  shortDesc    String?
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  price        Int
  oldPrice     Int?
  isNew        Boolean  @default(false)
  isPromo      Boolean  @default(false) // акции
  isBestseller Boolean  @default(false) // бестселлеры
  skinTypes    String[] @default([])
  sortOrder    Int      @default(0)
  featuredSortOrder Int? // если задан — товар показывается на главной в этом порядке; иначе на главной рандом
  imageUrl     String?
  imageUrls    String[] @default([]) // несколько фото товара
  imageFocusX  Int?     // точка фокуса главного фото (0–100), для object-position по X
  imageFocusY  Int?     // точка фокуса главного фото (0–100), для object-position по Y
  composition  String?  // состав
  components   String?  // компоненты
  extraField1  String?  // тестовое текстовое поле 1
  extraField2  String?  // тестовое текстовое поле 2
  articleCode  String?  // артикул, напр. SP2081
  problemText  String?  @db.Text // Проблема: ...
  careStageText String? @db.Text // Этап ухода
  skinTypesLine String? @db.Text // Тип кожи (строка для карточки)
  scientistsTitle String? @default("Что говорят ученые?")
  researchLinks Json?   // [{ "label": "...", "url": "https://..." }]
  forWhatText  String?  @db.Text // блок «Для чего?»
  howItWorksLines Json? // массив строк — пункты «Как работает?»
  howToUseText String?  @db.Text
  inciText     String?  @db.Text // INCI / из чего состоит
  volumeText   String?  // Объём: 30 мл
  shelfLifeText String? // Срок годности
  countryText  String?  // Страна производства
  inStock      Boolean  @default(true)
  linkWildberries  String? // карточка на Wildberries
  linkOzon         String? // Ozon
  linkYandexMarket String? // Яндекс Маркет
  dermatologistVideoUrl String? // видео-обзор дерматолога (YouTube, Vimeo, прямой mp4/webm)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orderItems   OrderItem[]
  pageViews    PageView[]
  userFavorites UserFavorite[]
}

model UserFavorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, productId])
}

model Order {
  id            String      @id @default(cuid())
  userId        String?
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  email         String
  phone         String
  name          String
  address       String
  /// placed | assembling | shipping | delivered (legacy: pending → как оформлен)
  status        String      @default("placed")
  promoCode     String?
  promoId       String?
  paymentId     String?
  total         Int
  /// Секретная ссылка для формы отзыва после заказа
  reviewToken   String?     @unique
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
  review        CustomerReview?
}

/// Отзыв покупателя (после заказа); на сайте только после одобрения в админке
model CustomerReview {
  id         String   @id @default(cuid())
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  authorName String
  body       String   @db.Text
  rating     Int      @default(5)
  /// URL изображений отзыва (/uploads/reviews/…)
  imageUrls  String[] @default([])
  status     String   @default("pending") // pending | approved | rejected
  /// Промокод −10% на следующий заказ (создаётся при одобрении)
  rewardCode String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// Вопрос с сайта (в админку, без публикации)
model SiteQuestion {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  body      String   @db.Text
  status    String   @default("new") // new | done
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  title     String
  price     Int
  quantity  Int
}

model Promo {
  id          String     @id @default(cuid())
  code        String     @unique
  percent     Int
  /// Фиксированная скидка в рублях с суммы заказа (если > 0 — приоритет над процентом)
  discountRub Int?
  description String?
  maxUses      Int?
  usedCount   Int        @default(0)
  validFrom   DateTime?
  validTo     DateTime?
  active      Boolean    @default(true)
  /// Промокод дерматолога: в админке считаются заказы и вознаграждение (% от суммы заказов)
  isDermatologist           Boolean @default(false)
  /// Процент от суммы заказов (поле total) для расчёта вознаграждения дерматологу; 0–100
  dermatologistRewardPercent Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  uses        PromoUse[]
}

/// Глобальный счётчик прокруток колеса (каждый 50-й — приз Telegram)
model WheelGlobalCounter {
  id    String @id
  spins Int    @default(0)
}

/// Ограничение частоты: не чаще одного вращения в час на пару email+телефон
model WheelSpinLog {
  id        String   @id @default(cuid())
  emailNorm String
  phoneNorm String
  createdAt DateTime @default(now())

  @@index([emailNorm, phoneNorm, createdAt])
}

model PromoUse {
  id        String   @id @default(cuid())
  promoId   String
  promo     Promo    @relation(fields: [promoId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   String
  usedAt    DateTime @default(now())
}

model Mailing {
  id        String   @id @default(cuid())
  subject   String
  body      String
  sentAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserNotification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PageView {
  id        String   @id @default(cuid())
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  path      String
  userId    String?
  createdAt DateTime @default(now())
}

/// Акционные баннеры на главной (карусель на всю ширину экрана)
model HomePromoBanner {
  id          String   @id @default(cuid())
  imageUrl    String
  linkUrl     String   @default("")
  buttonText  String   @default("")
  buttonColor String   @default("#18181b")
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Карточки «Выберите вашу проблему» под баннерами: фото, заголовок, ссылка в каталог (с фильтром)
model HomeConcernCard {
  id           String   @id @default(cuid())
  title        String
  imageUrl     String
  catalogQuery String   @default("") // например category=serums → ссылка /catalog?category=serums
  sortOrder    Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Квиз подбора: вопрос (заголовок), ответы ведут в каталог/товар или к следующему вопросу
model QuizQuestion {
  id               String        @id @default(cuid())
  title            String        // текст в шапке, напр. "Выберите тип вашей кожи"
  sortOrder        Int           @default(0)
  active           Boolean       @default(true)
  answers          QuizAnswer[]  @relation("QuizQuestionAnswers")
  incomingAnswers  QuizAnswer[]  @relation("QuizAnswerNext")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model QuizAnswer {
  id             String        @id @default(cuid())
  questionId     String
  question       QuizQuestion   @relation("QuizQuestionAnswers", fields: [questionId], references: [id], onDelete: Cascade)
  label          String        // текст варианта, напр. "Сухая"
  linkUrl        String        @default("") // куда ведёт: /catalog?skin=dry
  nextQuestionId String?
  nextQuestion   QuizQuestion?  @relation("QuizAnswerNext", fields: [nextQuestionId], references: [id], onDelete: SetNull)
  sortOrder      Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

/// Статьи/исследования на главной (блок «Исследования косметологии»): название, ссылка, описание
model HomeArticle {
  id          String   @id @default(cuid())
  title       String   // название статьи
  linkUrl     String   @default("") // ссылка при клике
  description String  @default("") // описание (краткий текст на карточке)
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
