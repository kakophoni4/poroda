# PostgreSQL (каталог, заказы, админка)
DATABASE_URL="postgresql://poroda:poroda@127.0.0.1:5433/poroda?schema=public"
# На проде: postgresql://USER:PASS@127.0.0.1:5432/poroda

# !!! ОБЯЗАТЕЛЬНО для production !!!
# Секрет для подписи сессий (HMAC-SHA256). Сгенерируй криптостойкую строку:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Без секрета приложение упадёт при старте в проде.
SESSION_SECRET=change-me-in-production

# Альфа-Банк (оплата). Два варианта по URL:
# — all2pay (JSON): https://doc.all2pay.net/integration/router/alfa-api.html
#   Пример UAT: https://api.uat.all2pay.net/v1
# — RBS REST / тестовая личка Альфы (form-urlencoded): см.
#   https://alfa.rbsuat.com/sandbox/ru/integration/api/rest.html
#   Пример теста: https://alfa.rbsuat.com/payment/rest
ALFABANK_USERNAME=
ALFABANK_PASSWORD=
ALFABANK_CLIENT_ID=
ALFABANK_API_URL=https://alfa.rbsuat.com/payment/rest
#
# ФФД 1.2 (чек в orderBundle + taxSystem в register.do) — https://doc.all2pay.net/integration/router/alfa-api.html
# Коды способ/предмет расчёта — цифры 1212/1214; «без НДС» для taxType чаще 6, при сбое — 10
ALFABANK_TAX_SYSTEM=usn_income
ALFABANK_VAT_TYPE=none
ALFABANK_DELIVERY_VAT_TYPE=none
ALFABANK_PAYMENT_METHOD=full_prepayment
ALFABANK_PAYMENT_OBJECT=commodity
ALFABANK_DELIVERY_PAYMENT_OBJECT=service
ALFABANK_FFD_VERSION=1.2

# Подпись callback-уведомлений (симметричный ключ, общий с банком / all2pay) — HMAC-SHA256, см.:
#   https://doc.all2pay.net/integration/router/router-callbacks.html
# Сгенерировать, например: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# тот же ключ в личном кабинете all2pay для callback. Без ключа: статусы могут проставляться, но
# `signatureValid=false` в `PaymentEvent`.
ALFABANK_CALLBACK_SECRET=

# Логировать в консоль сервера тело register.do (пароль замаскирован) — отладка UAT; на проде не включать
# PAYMENT_DEBUG_LOG_REGISTER=1

# Публичный URL сайта (https, без слеша в конце) — в register.do уходит
#   callbackUrl = {NEXT_PUBLIC_SITE_URL}/api/payment/webhook
# Нужен и для ссылок в письмах (подтверждение email, сброс пароля).
NEXT_PUBLIC_SITE_URL=https://porodacosmetics.ru

# Почта (nodemailer / SMTP). «Глушилка» для локалки: false — письма не уходят ([mail disabled] в логе); true — реальная отправка.
EMAIL_ENABLED=true
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
# true — порт 465 (SSL); false — например 587 (STARTTLS)
SMTP_SECURE=true
SMTP_USER=no-reply@porodacosmetics.ru
# Пароль приложения (Yandex / Mail и т.д.), не обычный пароль ящика
SMTP_PASSWORD=
# От кого: "Имя <addr@domain>" либо только email
EMAIL_FROM="PORODA Cosmetics <no-reply@porodacosmetics.ru>"

# Telegram: уведомления админам о заказе и об онлайн-оплате (только HTTP Bot API, без локального бота)
# TELEGRAM_BOT_TOKEN=        # токен у @BotFather
# TELEGRAM_CHAT_ID=           # id чата, приватной группы (бот — админ) или личный id админа
# TELEGRAM_NOTIFY_ENABLED=true  # false — тихо не слать, креды можно не убирать

# Пароль первого админа при seed (опционально)
# ADMIN_SEED_PASSWORD=admin123

# Куда складывать загружаемые админом/пользователями файлы (опционально).
# По умолчанию: <корень проекта>/public/uploads — удобно локально.
# В проде на VPS лучше задать постоянный путь ВНЕ папки сборки и сделать симлинк
# или nginx alias /uploads → этот путь, иначе файлы исчезнут при следующем npm run build.
# UPLOAD_DIR=/var/poroda/uploads
